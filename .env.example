# ─────────────────────────────────────────────────────────────────────────────
# AURA — шаблон переменных окружения
# Скопируйте в .env и заполните реальными значениями перед запуском.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Django Core ─────────────────────────────────────────────────────────────
# Генерация: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

DEBUG=False

# Через запятую без пробелов
ALLOWED_HOSTS=*

# ─── Безопасность ────────────────────────────────────────────────────────────
# Укажите все домены, с которых принимаются CSRF-запросы
CSRF_TRUSTED_ORIGINS=*

# ─── База данных (PostgreSQL) ─────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=aura_db
DB_USER=aura_user
DB_PASSWORD=strong-db-password-here
DB_HOST=aura-db
DB_PORT=5432

# ─── Redis (кэш) ────────────────────────────────────────────────────────────
REDIS_URL=redis://aura-redis:6379/0

# ─── Статика и медиа ─────────────────────────────────────────────────────────
STATIC_URL=/static/
MEDIA_URL=/media/

# Bump on releases that change templates/static assets to invalidate PWA caches.
PWA_CACHE_VERSION=2026.05.25.1

# ─── Локализация ─────────────────────────────────────────────────────────────
TIME_ZONE=Asia/Bishkek

# ─── Gunicorn (опционально, переопределяет gunicorn.conf.py) ────────────────
# GUNICORN_WORKERS=5
