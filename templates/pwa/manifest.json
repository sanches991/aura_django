{% load static %}{
  "id": "/menu/",
  "name": "AURA Fine Dining Menu",
  "short_name": "AURA Menu",
  "description": "Digital restaurant menu for AURA Fine Dining.",
  "lang": "ru",
  "dir": "ltr",
  "start_url": "/menu/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait-primary",
  "background_color": "#1f4430",
  "theme_color": "#2d5a3d",
  "categories": ["food", "lifestyle"],
  "icons": [
    {
      "src": "{% static 'images/pwa/icon-192.png' %}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "{% static 'images/pwa/icon-512.png' %}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "{% static 'images/pwa/icon-maskable-192.png' %}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "{% static 'images/pwa/icon-maskable-512.png' %}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Open menu",
      "short_name": "Menu",
      "url": "/menu/",
      "icons": [
        {
          "src": "{% static 'images/pwa/icon-192.png' %}",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
}
